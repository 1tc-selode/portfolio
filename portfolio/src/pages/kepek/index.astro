---
import Layout from '../../layouts/Layout.astro';
import { projects, formatDate } from '../../data/projects';
const sorted = [...projects].sort((a, b) => b.date.localeCompare(a.date));
---

<Layout>
	<header>
		<a href="/" class="logo">SELETYE ODETT</a>
		<nav>
			<a href="/kepek" class="active">Képek</a>
			<a href="/videok">Videók</a>
			<a href="/rolam">Rólam</a>
			<a href="mailto:odettphotography@gmail.com">Kapcsolat</a>
		</nav>
	</header>

	<main>

		<div class="filter-bar">
			<button class="filter-btn active" data-filter="minden">Minden</button>
			<button class="filter-btn" data-filter="Koncert">Koncert</button>
			<button class="filter-btn" data-filter="Kávézó">Kávézó</button>
			<button class="filter-btn" data-filter="Editorial">Editorial</button>
			<button class="filter-btn" data-filter="Más">Más</button>
		</div>

		<div class="projects-grid">
			{sorted.map((project) => (
				<a href={`/kepek/${project.slug}`} class="project-card" data-category={project.category}>
					<div class="project-cover">
						<img src={project.cover} alt={project.title} loading="lazy" />
					</div>
					<div class="project-meta">
						<span class="meta-title">{project.title}</span>
						<span class="meta-right">
							<span class="meta-cat">{project.category}</span>
							<span class="meta-year">{project.date}</span>
						</span>
					</div>
				</a>
			))}
		</div>

		<script>
			// Fekvő képeknél contain, állóknál cover
			document.querySelectorAll('.project-cover img').forEach(img => {
				const el = img as HTMLImageElement;
				const check = () => {
					if (el.naturalWidth > el.naturalHeight) {
						el.classList.add('is-landscape');
					}
				};
				if (el.complete) check();
				else el.addEventListener('load', check);
			});

			document.querySelectorAll('.filter-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					const filter = btn.getAttribute('data-filter');
					document.querySelectorAll('.project-card').forEach(card => {
						const cat = card.getAttribute('data-category');
						(card as HTMLElement).style.display = (filter === 'minden' || cat === filter) ? '' : 'none';
					});
				});
			});
		</script>
	</main>

	<footer>
		<span>© 2025 Seletye Odett</span>
		<div class="footer-links">
			<a href="mailto:odettphotography@gmail.com">E-mail</a>
			<a href="https://instagram.com/odettphoto" target="_blank" rel="noopener">Instagram</a>
			<a href="https://tiktok.com/@odettphoto" target="_blank" rel="noopener">TikTok</a>
		</div>
	</footer>
</Layout>

<style>
	header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 22px 32px;
		border-bottom: 1px solid #999;
	}

	.logo {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 700;
		font-size: 1.3rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	nav {
		display: flex;
		gap: 32px;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #555;
	}

	nav a:hover, nav a.active { color: #111; }

	.page-title-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 14px 32px;
		border-bottom: 1px solid #999;
	}

	.page-title {
		font-size: 0.75rem;
		letter-spacing: 0.1em;
	}

	/* ── FILTER ── */
	.filter-bar {
		display: flex;
		justify-content: center;
		gap: 8px;
		padding: 16px 32px;
	}

	.filter-btn {
		background: none;
		border: none;
		padding: 6px 16px;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #aaa;
		cursor: pointer;
		transition: color 0.2s;
	}

	.filter-btn:hover { color: #111; }

	.filter-btn.active {
		color: #111;
		font-weight: 500;
	}

	/* ── GRID ── */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		padding: 24px 32px 64px;
	}

	.project-card {
		display: block;
	}

	.project-cover {
		width: 100%;
		aspect-ratio: 2/3;
		background: #f5f4f0;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.project-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.45s ease;
	}

	.project-cover img.is-landscape {
		object-fit: contain;
	}

	.project-card:hover .project-cover img:not(.is-landscape) {
		transform: scale(1.04);
	}

	.project-meta {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: flex-start;
		gap: 8px;
		padding: 10px 0 14px 0;
	}

	.meta-title {
		font-size: 0.9rem;
		font-weight: 500;
		color: #111;
		line-height: 1.3;
	}

	.meta-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 2px;
		flex-shrink: 0;
	}

	.meta-cat {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #888;
	}

	.meta-year {
		font-size: 0.7rem;
		color: #bbb;
	}

	/* ── FOOTER ── */
	footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 16px 32px;
		border-top: 1px solid #999;
		font-size: 0.78rem;
		color: #666;
		flex-wrap: wrap;
		gap: 8px;
	}

	.footer-links {
		display: flex;
		gap: 20px;
	}

	.footer-links a:hover { color: #111; }

	@media (max-width: 900px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 700px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 12px;
			padding: 12px 16px 48px;
		}
		.project-card {
		}
		.project-cover {
			aspect-ratio: 2/3;
		}
		.project-meta {
			padding: 10px 0 12px;
		}
		header { padding: 18px 16px; }
		footer { padding: 16px; }
		.filter-bar {
			flex-wrap: wrap;
			gap: 2px 0;
			padding: 8px 16px;
			justify-content: flex-start;
		}
		.filter-btn {
			padding: 6px 14px;
			font-size: 0.7rem;
		}
	}
</style>
